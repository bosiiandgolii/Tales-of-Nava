# ============================================================================
# Unity .gitignore
# ============================================================================

# ── Unity generated ─────────────────────────────────────────────────────────
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# ── Asset imports ───────────────────────────────────────────────────────────
# Blender backup files
*.blend1
*.blend1.meta

# ── Memory & Recordings ────────────────────────────────────────────────────
/[Mm]emoryCaptures/
/[Rr]ecordings/

# ── IDE — JetBrains Rider ──────────────────────────────────────────────────
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user
.idea/

# ── IDE — Visual Studio / VS Code ──────────────────────────────────────────
.vs/
.vscode/
*.suo
*.user
*.userprefs

# ── Autogenerated solution & project files ─────────────────────────────────
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.tmp
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ── Unity generated meta for autogenerated files ──────────────────────────
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ── Unity crash reports ────────────────────────────────────────────────────
sysinfo.txt
mono_crash.*

# ── Builds ──────────────────────────────────────────────────────────────────
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
*.exe
*.ipa

# ── Crashlytics ─────────────────────────────────────────────────────────────
crashlytics-build.properties

# ── TestRunner ──────────────────────────────────────────────────────────────
InitTestScene*.unity*
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# ── Addressables ────────────────────────────────────────────────────────────
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# ── Visual Scripting ────────────────────────────────────────────────────────
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# ── Gradle (Android builds) ────────────────────────────────────────────────
.gradle/
launchpadProjects/

# ── NuGet ───────────────────────────────────────────────────────────────────
/[Nn]u[Gg]et/
*.nupkg
**/[Pp]ackages/*
!**/[Pp]ackages/manifest.json
!**/[Pp]ackages/packages-lock.json

# ── OS generated files ──────────────────────────────────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~

# ── Plastic SCM (if used) ──────────────────────────────────────────────────
*.private.0
*.private
ignore.conf

# ── TextMesh Pro ────────────────────────────────────────────────────────────
/[Aa]ssets/TextMesh Pro/

# ── Burst debug info ───────────────────────────────────────────────────────
*.pdb
*.dSYM/

# ── Code Coverage ──────────────────────────────────────────────────────────
/[Cc]ode[Cc]overage/
